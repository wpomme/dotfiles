#!/bin/sh -

# \033[ -> ESC + [ -> Control Sequence Introducer (CSI)
# 32 -> green
# m -> ternimal character
START_COLOR='\033[32m'
END_COLOR='\033[0m'

if [ $# -eq 0 ]; then
  for dir_path in `echo $PATH | sed -e "s/:/\n/g"`
  do
    echo "${START_COLOR}${dir_path}${END_COLOR}"
    ls $dir_path 2> /dev/null
  done
fi

if [ $# -eq 1 ]; then
  ls $1 2> /dev/null
fi
